# FinRelief AI Production Backend Configuration
# Duplicate this file as .env and populate details

# Neon PostgreSQL connection string (e.g. postgresql://user:password@host/db?sslmode=require)
DATABASE_URL=postgresql://[user]:[password]@[host]/[dbname]?sslmode=require

# Gemini API credentials (optional, falls back to plain templates if empty)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT authentication security secret (change before deploying)
FINRELIEF_SECRET_KEY=generate-a-new-random-64-char-hex-string-for-production

# Allowed CORS origins for Vite client
FRONTEND_URL=http://localhost:5173
